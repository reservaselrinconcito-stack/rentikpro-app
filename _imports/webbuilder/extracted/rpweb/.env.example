# RentikPro Public API
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and never committed.

# Base URL of the RentikPro Worker (no trailing slash)
VITE_RENTIKPRO_API_BASE=https://<worker-domain>

# Property ID assigned by RentikPro
VITE_RENTIKPRO_PROPERTY_ID=XXX

# Public token for this property (read-only, safe for browser)
VITE_RENTIKPRO_PUBLIC_TOKEN=<token-publico-propiedad>
